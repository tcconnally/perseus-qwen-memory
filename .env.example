# Perseus Qwen Memory Agent — Environment Variables
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────
# Qwen Cloud API key (get one at https://bailian.console.aliyun.com/)
DASHSCOPE_API_KEY=your-api-key-here

# ── LLM Configuration ─────────────────────────────────────
LLM_PROVIDER=qwen
LLM_MODEL=qwen-max
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Memory Backend ────────────────────────────────────────
# "engram" (self-hosted, MIT) or "elastic" (cloud-managed)
MEMORY_BACKEND=engram

# Engram-rs (when MEMORY_BACKEND=engram)
# ENGRAM_BIN=engram
# ENGRAM_DB_PATH=~/.hermes/mnemosyne/data/mnemosyne.db

# Elastic Cloud (when MEMORY_BACKEND=elastic)
# ELASTIC_CLOUD_ID=your-deployment:dXMtY2VudHJhbDEuZ2Nw...
# ELASTIC_API_KEY=your-base64-api-key
# ELASTIC_MEMORY_INDEX=perseus-agent-memory

# ── Agent Behavior ────────────────────────────────────────
# MAX_CONTEXT_TOKENS=32000
# RECALL_COUNT=10
# AUTO_REFLECT=true
# CONFIDENCE_DECAY_RATE=0.05
